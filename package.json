{
  "name": "webchain",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "test:integration": "pnpm --filter @webchain/companion test:integration && pnpm --filter @webchain/mcp test:integration",
    "test:mcp-conformance": "pnpm --filter @webchain/mcp test:integration",
    "test:integrations": "pnpm --filter @examples/webchain-agent-smokes test:smoke-only",
    "lint": "biome check .",
    "format": "biome format --write .",
    "dev:web": "pnpm --filter @webchain/control-plane dev",
    "dev:extension": "pnpm --filter @webchain/extension dev",
    "dev:companion": "pnpm --filter @webchain/companion dev",
    "dev:mcp": "pnpm --filter @webchain/mcp dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.23.1",
    "turbo": "^2.10.5",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "@vitest/coverage-v8": "4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asap-protocol/webchain.git"
  },
  "bugs": {
    "url": "https://github.com/asap-protocol/webchain/issues"
  },
  "homepage": "https://github.com/asap-protocol/webchain#readme"
}
