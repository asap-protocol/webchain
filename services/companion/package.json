{
  "name": "@webchain/companion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./server": "./src/server.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@webchain/protocol": "workspace:*",
    "@webchain/runtime": "workspace:*",
    "fastify": "^5.8.2",
    "zod": "^4.3.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asap-protocol/webchain.git",
    "directory": "services/companion"
  },
  "bugs": {
    "url": "https://github.com/asap-protocol/webchain/issues"
  },
  "homepage": "https://github.com/asap-protocol/webchain#readme"
}
